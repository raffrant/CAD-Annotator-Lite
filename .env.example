# Copy to .env and insert your server-side key. Never put the key in public/.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
AI_PROVIDER=ollama

# Optional local fallback
OLLAMA_MODEL=qwen3-vl:4b
# Increase only if complex drawings still truncate and sufficient RAM/VRAM is available.
OLLAMA_NUM_CTX=16384

# Optional CAD/Python overrides when installed outside the detected defaults
# FREECAD_CMD=C:\Program Files\FreeCAD 1.1\bin\freecadcmd.exe
# PYTHON=C:\Path\To\python.exe
